# API URL for backend (defaults to http://localhost:5000 in development)
# For production deployment, set this to your deployed backend URL
# Example: https://document-upload-api.onrender.com
VITE_API_URL=

# Firebase Configuration
# Get these from your Firebase Console (Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
